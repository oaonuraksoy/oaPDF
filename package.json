{
  "name": "oapdf",
  "productName": "oaPDF",
  "version": "1.0.0",
  "description": "Yaka Kartı Otomasyonu",
  "main": "src/main.js",
  "build": {
    "appId": "com.tr.oahub.oapdf",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/img/app_icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^26.8.1"
  }
}
